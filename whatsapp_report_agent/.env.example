# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email delivery ────────────────────────────────────────────────────────────
REPORT_RECIPIENT_EMAIL=reports@example.com

# Provider: "resend" (default) or "smtp"
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@example.com

# Resend (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_...

# SMTP (used when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword

# Optional SMTP retry tuning
# SMTP_RETRY_COUNT=3
# SMTP_RETRY_BASE_DELAY=2
# SMTP_RETRY_MAX_DELAY=30

# ── Scheduled daily report ────────────────────────────────────────────────────
# Set to "true" to send an automated report email every day at 8 PM (TZ below)
ENABLE_DAILY_REPORT_EMAIL=false

# ── Factory / sender mapping ──────────────────────────────────────────────────
# Map WhatsApp sender phone numbers (digits only) to factory keys defined in config.py
# Comma-separated pairs: PHONE=factory_key
# SENDER_TO_FACTORY_MAP=919900011122=plant_a,919900033344=plant_b
#
# Or JSON format:
# SENDER_TO_FACTORY_MAP={"919900011122":"plant_a","919900033344":"plant_b"}

# Fallback factory for senders not in the map (leave blank to reject unknown senders)
# DEFAULT_FACTORY_KEY=plant_a

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata

# ── Storage paths ─────────────────────────────────────────────────────────────
DATA_XLSX_PATH=out/data.xlsx
OUTPUT_DIR=out

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=whatsapp_report_agent.log
